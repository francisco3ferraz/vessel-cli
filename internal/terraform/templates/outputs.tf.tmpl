# Generated by vessel-cli.

output "ecr_repository_uri" {
  description = "Full ECR repository URI (registry/name)."
  value       = aws_ecr_repository.app.repository_url
}

output "ecs_cluster_arn" {
  description = "ARN of the ECS cluster."
  value       = aws_ecs_cluster.app.arn
}

output "ecs_service_arn" {
  description = "ARN of the ECS service."
  value       = aws_ecs_service.app.id
}

output "ecs_task_def_arn" {
  description = "ARN of the ECS task definition."
  value       = aws_ecs_task_definition.app.arn
}

output "alb_dns_name" {
  description = "DNS name of the Application Load Balancer (empty when ALB is not enabled)."
  value       = {{if .LoadBalancer}}aws_lb.app.dns_name{{else}}""{{end}}
}

output "alb_arn" {
  description = "ARN of the Application Load Balancer (empty when ALB is not enabled)."
  value       = {{if .LoadBalancer}}aws_lb.app.arn{{else}}""{{end}}
}
