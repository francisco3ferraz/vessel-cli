# Generated by vessel-cli.

variable "app_name" {
  description = "Application name — used for all resource names."
  type        = string
}

variable "aws_region" {
  description = "AWS region to deploy into."
  type        = string
}

variable "image_tag" {
  description = "Docker image tag to deploy (git SHA by default)."
  type        = string
}

variable "allowed_cidr" {
  description = "CIDR block allowed inbound to app_port. Default: caller's detected IP/32. Use --allow-public for 0.0.0.0/0."
  type        = string
  # No default — vessel-cli always supplies this value explicitly.
  # A missing value here is a render-time error, not a silent fallback.
}

variable "app_port" {
  description = "Container port to expose. Matches --port flag (default 8080)."
  type        = number
  default     = 8080
}

variable "env_vars" {
  description = "Environment variables injected into the ECS container. Managed by vessel-cli via --env KEY=VALUE."
  type        = list(object({ name = string, value = string }))
  default     = []
}

variable "secret_refs" {
  description = "Secrets Manager references injected as secrets into the ECS container. Managed by vessel-cli via --secret KEY=VALUE."
  type        = list(object({ name = string, valueFrom = string }))
  default     = []
}

variable "certificate_arn" {
  description = "ACM certificate ARN for HTTPS listener (empty = HTTP only). Set via --certificate-arn."
  type        = string
  default     = ""
}
